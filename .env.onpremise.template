# On-Premise configuratie — Working Local
# Kopieer naar .env en vul in
# .env staat in .gitignore — nooit committen

# Cloudflare tunnel token
# Aanmaken via: Cloudflare dashboard → Zero Trust → Networks → Tunnels → Create tunnel
# Kies "cloudflared" als connector, kopieer het token
CLOUDFLARE_TUNNEL_TOKEN=VERVANG_MET_TUNNEL_TOKEN

# Urbackup backup opslag pad op de host (optioneel — standaard Docker volume)
# URBACKUP_BACKUP_PATH=/mnt/backup
